# Frontend Environment Variables

# API Configuration
# Backend API URL - used in production/preview deployments
# Leave blank in development to use localhost:5000 (via vite.config.js proxy)
# In Vercel, set to your backend URL, including protocol.
# Examples:
# VITE_API_URL=https://trident-backend-staging.vercel.app
# VITE_API_URL=https://trident-backend-prod.vercel.app
VITE_API_URL=https://your-backend.vercel.app

# Application Configuration
# Display name for the application
VITE_APP_NAME=TRIDENT Match Portal

# Optional: Analytics or tracking
# VITE_ANALYTICS_ID=
